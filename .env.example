# Copie este arquivo para .env e preencha os valores reais
# cp .env.example .env

# ── Banco de dados ────────────────────────────────────────────────────────────
DB_NAME=helpdeskWS
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# ── Aplicação ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=uma_chave_secreta_longa_e_aleatoria
JWT_ACCESS_TOKEN_EXPIRES=28800
EMAIL_SERVICE_ENABLED=true

# ── E-mail IMAP ───────────────────────────────────────────────────────────────
EMAIL_HOST=
EMAIL_PORT=993
EMAIL_USER=
EMAIL_PASSWORD=sua_senha_email

# ── E-mail SMTP ───────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=sua_senha_email
